{
  "engine": "pstretch",
  "title": "Pstretch - real-time PaulStretch ambient time-smear",
  "subtitle": "clean-room PaulStretch; live / capture / SD-file source, stretch-through",

  "knobs": {
    "Pitch": "pitch shift +/- 1 octave; Alt = CLIP select (SD)",
    "Position": "diffusion / smear (clean .. full wash); Alt = SCRUB clip playhead (SD)",
    "Size": "STRETCH 1x .. 64x",
    "Envelope": "output tone (low-pass)",
    "Mix (SOS)": "dry/wet",
    "Cycle": "MOD LFO rate; Alt = clock-sync",
    "Glow": "MOD depth (0 = off)"
  },

  "pads": {
    "Play": "FREEZE the read head (drone)",
    "Reverse": "RE-GRAB the ring (Capture mode)",
    "Grit": "-",
    "Flux": "-",
    "Seq": "-"
  },

  "ring": "stretch marker; live/capture/SD/freeze colour; clip dots (Alt, SD)",

  "crossfade": "A/B blend of the two decks",

  "switches": {
    "Mode (L/C/R)": "SOURCE: Reel=Capture / Slice=Live / Drift=SD",
    "Routing (L/C/R)": "stereo image: centre / A|B / random",
    "CV target (U/C/D)": "-",
    "Out trims A/B": "output trims"
  },

  "transport": {
    "Tap": "-",
    "Spot": "-"
  },

  "cv": {
    "Size/Pos A/B": "stretch (additive)",
    "Mix A/B": "dry/wet (additive)",
    "V/Oct A/B": "pitch (1V/oct, additive)",
    "Crossfade CV": "A/B blend"
  },

  "gates": {
    "Gate in A/B": "re-grab (Capture) / freeze toggle",
    "Gate out A/B": "LFO cycle (tempo-synced clock)"
  },

  "mod_midi": {
    "Mod CV out A/B": "LFO as 0..1 CV"
  }
}
